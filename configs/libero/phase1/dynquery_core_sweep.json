{
  "sweep_name": "dynquery_core_sweep",
  "version": "1.0.0",
  "description": "DynQueryWorldModel core sweep. 5 representative conditions covering baseline ablation, core feature progression, query scaling, and 2-stage training.",

  "common": {
    "model_generation": "dynquery",
    "target_mode": "temporal_query_residual",
    "eval_horizon": 8,
    "train_horizon": 8,
    "phase0_compatible": 1,
    "max_steps": 150000,
    "lr": "1e-4",
    "world_model_batch_size": 64,
    "batch_size": 8,
    "precision": "bf16",
    "tf32": 1,
    "lr_scheduler": "constant",
    "warmup_ratio": 0.0,
    "seed": 42,
    "rank_temperature": 0.07,
    "action_bins": 256,
    "action_emb_dim": 128,
    "action_conditioning_mode": "discrete_tokens",
    "encoder_channels": 256,
    "hidden_dim": 256,
    "n_heads": 4,
    "n_context_layers": 2,
    "n_fuser_layers": 2,
    "n_scorer_layers": 2,
    "ffn_dim": 1024,
    "dropout": 0.0,
    "residual_output_activation": "tanh",
    "residual_output_scale": 1.0,
    "pixel_output_activation": "sigmoid",
    "dynamic_threshold": 0.05,
    "dynamic_dilate_kernel": 7,
    "roi_crop_size": 64,
    "lambda_image": 0.1,
    "lambda_dynamic": 1.0,
    "lambda_static": 0.2,
    "lambda_query": 0.5,
    "num_eval_windows": 200,
    "num_ranking_windows": 100,
    "window_position_mode": "episode_phases",
    "negative_eval_types": "same_phase,temporal_shift,action_noise,mixed",
    "temporal_shift_max": 3,
    "action_noise_std": 0.15,
    "action_ablation": 0,
    "save_debug_visuals": 0
  },

  "experiments": [
    {
      "exp_name": "dq_baseline",
      "stage": "dq_a",
      "description": "Baseline: all 4 core features disabled, no motion bias, no scorer. Establishes the performance floor.",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_action_conditioned_mask": 0,
      "predictor_mode": "linear_expand",
      "use_dynamic_residual_gate": 0,
      "lambda_mask_dynamic": 0.0,
      "lambda_query_delta_sparse": 0.0,
      "use_motion_bias": 0,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "dq_core14_no_scorer",
      "stage": "dq_a",
      "description": "Cores 1-4 all enabled + motion bias, no ActionFutureScorer. Isolates the reconstruction-side improvements.",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_action_conditioned_mask": 1,
      "predictor_mode": "query_wise",
      "use_dynamic_residual_gate": 1,
      "lambda_mask_dynamic": 0.1,
      "lambda_query_delta_sparse": 0.001,
      "use_motion_bias": 1,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "dq_full_rank1",
      "stage": "dq_b",
      "description": "Full DynQuery: all 4 cores + motion bias + ActionFutureScorer + mixed negatives, lambda_rank=1.0.",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_action_conditioned_mask": 1,
      "predictor_mode": "query_wise",
      "use_dynamic_residual_gate": 1,
      "lambda_mask_dynamic": 0.1,
      "lambda_query_delta_sparse": 0.001,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "mixed",
      "negative_mix": "same_task_other_window:0.5,temporal_permutation:0.25,zero_random:0.25",
      "enabled": true
    },
    {
      "exp_name": "dq_full_q16",
      "stage": "dq_b",
      "description": "Full DynQuery with Q=16 dynamic queries. Tests whether more queries improve action discrimination.",
      "history_length": 2,
      "num_dynamic_queries": 16,
      "use_action_conditioned_mask": 1,
      "predictor_mode": "query_wise",
      "use_dynamic_residual_gate": 1,
      "lambda_mask_dynamic": 0.1,
      "lambda_query_delta_sparse": 0.001,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "mixed",
      "negative_mix": "same_task_other_window:0.5,temporal_permutation:0.25,zero_random:0.25",
      "enabled": true
    },
    {
      "exp_name": "dq_full_2stage",
      "stage": "dq_b",
      "description": "Two-stage: warm-start from dq_core14_no_scorer (50k), fine-tune full DynQuery (100k). Total=150k steps.",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_action_conditioned_mask": 1,
      "predictor_mode": "query_wise",
      "use_dynamic_residual_gate": 1,
      "lambda_mask_dynamic": 0.1,
      "lambda_query_delta_sparse": 0.001,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "mixed",
      "negative_mix": "same_task_other_window:0.5,temporal_permutation:0.25,zero_random:0.25",
      "max_steps": 100000,
      "init_from_checkpoint": "@dq_core14_no_scorer",
      "enabled": true
    }
  ]
}
