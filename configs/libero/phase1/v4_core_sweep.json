{
  "sweep_name": "v4_core_sweep",
  "version": "1.0.0",
  "description": "Phase1 v4 TemporalDynamicQueryResidualWM core sweep. v4a = no scorer, v4b = with ActionFutureScorer.",

  "common": {
    "model_generation": "v4",
    "target_mode": "temporal_query_residual",
    "eval_horizon": 7,
    "train_horizon": 7,
    "phase0_compatible": 1,
    "max_steps": 150000,
    "lr": "1e-4",
    "world_model_batch_size": 64,
    "batch_size": 8,
    "precision": "bf16",
    "tf32": 1,
    "lr_scheduler": "constant",
    "warmup_ratio": 0.0,
    "seed": 42,
    "rank_temperature": 0.07,
    "action_bins": 256,
    "action_emb_dim": 128,
    "action_conditioning_mode": "discrete_tokens",
    "encoder_channels": 256,
    "hidden_dim": 256,
    "n_heads": 4,
    "n_context_layers": 2,
    "n_fuser_layers": 2,
    "n_scorer_layers": 2,
    "ffn_dim": 1024,
    "dropout": 0.0,
    "residual_output_activation": "tanh",
    "residual_output_scale": 1.0,
    "pixel_output_activation": "sigmoid",
    "dynamic_threshold": 0.05,
    "dynamic_dilate_kernel": 7,
    "roi_crop_size": 64,
    "lambda_image": 0.1,
    "lambda_dynamic": 1.0,
    "lambda_static": 0.2,
    "lambda_query": 0.5,
    "lambda_sparse": 0.01,
    "num_eval_windows": 200,
    "num_ranking_windows": 100,
    "window_position_mode": "random",
    "action_ablation": 0,
    "save_debug_visuals": 0
  },

  "experiments": [
    {
      "exp_name": "v4a_q8_k2_nomotion",
      "stage": "v4a",
      "description": "v4a baseline — no motion bias, no scorer",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 0,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4a_q8_k2_motion",
      "stage": "v4a",
      "description": "v4a + motion bias on DynamicQueryExtractor",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4a_q16_k2_motion",
      "stage": "v4a",
      "description": "v4a + motion bias + Q=16 queries",
      "history_length": 2,
      "num_dynamic_queries": 16,
      "use_motion_bias": 1,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4a_q8_k3_motion",
      "stage": "v4a",
      "description": "v4a + motion bias + K=3 history frames",
      "history_length": 3,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 0,
      "lambda_rank": 0.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q8_k2_rank05_motion",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer, lambda_rank=0.5",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 0.5,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q8_k2_rank1_motion",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer, lambda_rank=1.0 (default)",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q8_k2_rank2_motion",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer, lambda_rank=2.0",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 2.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q16_k2_rank1_motion",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer + Q=16",
      "history_length": 2,
      "num_dynamic_queries": 16,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q8_k3_rank1_motion",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer + K=3 history",
      "history_length": 3,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "same_task_other_window",
      "negative_mix": null,
      "enabled": true
    },
    {
      "exp_name": "v4b_q8_k2_rank1_mixedneg",
      "stage": "v4b",
      "description": "v4b — motion bias + scorer + mixed negatives (metadata; model uses batch fallback)",
      "history_length": 2,
      "num_dynamic_queries": 8,
      "use_motion_bias": 1,
      "use_action_future_scorer": 1,
      "lambda_rank": 1.0,
      "rank_margin": 0.1,
      "negative_type": "mixed",
      "negative_mix": "same_task_other_window:0.5,temporal_permutation:0.25,zero_random:0.25",
      "enabled": true
    }
  ]
}
